[vast]
username = your_vast_username
password = your_vast_password
address = 172.19.16.30
timeout = 30
# Filesystem path of the scratch quota shown on /scratch
scratch_path = /trace/scratch

[grouper]
base_url = https://grouper.andrew.cmu.edu/grouper-ws/servicesRest/v2_5_600
username = trace-gro-svc
stem = Apps:XRAS:trace_groups
# Password is read from the GROUPER_PASSWORD environment variable (set in .env)
# Full colon-delimited Grouper group name that grants access to /scratch
scratch_access_group = Community:Department:ChemE:admins

[flask]
# Web server settings
port = 5001
host = 0.0.0.0
# Set debug=false in production (enables Shibboleth authentication, disables user search feature)
debug = true

[apache]
# Server hostname for Apache configuration
# Used by scripts/generate_apache_config.py to generate the Apache config
server_name = trace-vast-dashboard.wec.local.cmu.edu

[shibboleth]
# Shibboleth authentication endpoints (used when debug=false)
# These are standard paths when using Apache mod_shib
login_url = /Shibboleth.sso/Login
logout_url = /Shibboleth.sso/Logout

[cache]
ttl = 600

[logging]
# Production (debug=false): logs go to stderr → journalctl automatically (no file needed)
#   View with: journalctl -u apache2 -f   (or your httpd service name)
# Debug (debug=true): logs go to stderr + the file below (directory created automatically)
file = /tmp/vast-dashboard/app.log
